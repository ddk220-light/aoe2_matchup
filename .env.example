# =============================================================================
# Asset storage (Phase 1) — Railway Bucket + Postgres catalog credentials.
#
#   cp .env.example .env     # `.env` is gitignored — NEVER commit it
#   ...then fill in the values below.
#
# Read by aoe2x/assets/config.py and the publish CLI (python -m aoe2x.assets.publish).
# On Railway, the deployed app gets these as SERVICE env vars (reference the
# Bucket + Postgres services), not from this file. Leaving the BUCKET_* values
# blank keeps the app in fallback mode (serves /static exactly as today).
# =============================================================================

# --- Railway Bucket (S3-compatible) — for uploading + serving media ---
# Railway dashboard -> your project -> Create -> Bucket. Open the Bucket service's
# Variables tab and copy these (Railway names them ENDPOINT / ACCESS_KEY_ID /
# SECRET_ACCESS_KEY / BUCKET / REGION). The bucket is PRIVATE; the app serves media
# by redirecting /assets/<key> to a presigned URL.
BUCKET_ENDPOINT=https://storage.railway.app
BUCKET_ACCESS_KEY_ID=
BUCKET_SECRET_ACCESS_KEY=
BUCKET_NAME=
BUCKET_REGION=auto

# --- Railway Postgres (the queryable asset catalog) ---
# Use the PUBLIC connection string for local publish/verify (DATABASE_PUBLIC_URL —
# host ends in .proxy.rlwy.net). On Railway, the app service references the private
# ${{Postgres.DATABASE_URL}}. Blank = catalog falls back to the in-repo manifest.
DATABASE_URL=

# --- Which environment's data this run targets (catalog rows) ---
ASSET_ENV=staging
