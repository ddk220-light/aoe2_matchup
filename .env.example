# =============================================================================
# Asset storage (Phase 1) — R2 + Postgres catalog credentials.
#
#   cp .env.example .env     # `.env` is gitignored — NEVER commit it
#   ...then fill in the values below.
#
# Read by aoe2x/assets/config.py and the publish CLI (python -m aoe2x.assets.publish).
# On Railway, set these as SERVICE env vars instead — the deployed app uses those,
# not this file. Leaving CDN_BASE_URL or DATABASE_URL blank keeps the app in
# fallback mode (serves /static exactly as today): both must be set for R2 mode.
# =============================================================================

# --- Cloudflare R2 (S3-compatible) — needed to create the bucket + upload media ---
# Create under: Cloudflare dashboard -> R2 -> Manage R2 API Tokens
#   * Permission: Object Read & Write
#   * Scope: the single bucket below (least privilege)
# R2_ENDPOINT is https://<ACCOUNT_ID>.r2.cloudflarestorage.com  (account-specific).
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET=
R2_BUCKET=aoe2-assets

# --- Public base URL the browser loads media from ---
# After enabling public access on the bucket (R2 -> bucket -> Settings -> Public
# access), paste the managed r2.dev URL here, e.g. https://pub-xxxx.r2.dev
# (or a custom domain like https://cdn.aoe2matchup.com once DNS is set).
# Blank = fallback mode (no R2).  No trailing slash.
CDN_BASE_URL=

# --- Railway Postgres (the queryable asset catalog) ---
# Use the PUBLIC connection string for local publish/verify (host ends in
# .proxy.rlwy.net). On Railway the internal DATABASE_URL is auto-injected.
# Blank = fallback mode (no catalog DB).
DATABASE_URL=

# --- Which environment's data this run targets (db/<env>/... keys, catalog rows) ---
ASSET_ENV=staging
